{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/ai_human_oversight_attestation.schema.json",
  "title": "AI Human Oversight Attestation",
  "type": "object",
  "required": [
    "oversightRolesAssigned",
    "escalationPathDocumented",
    "overrideResponsibilityDeclared",
    "reviewWindowDays"
  ],
  "properties": {
    "oversightRolesAssigned": {
      "type": "boolean"
    },
    "escalationPathDocumented": {
      "type": "boolean"
    },
    "overrideResponsibilityDeclared": {
      "type": "boolean"
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

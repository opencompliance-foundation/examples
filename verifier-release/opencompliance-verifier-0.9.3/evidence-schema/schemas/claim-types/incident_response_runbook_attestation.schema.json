{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/incident_response_runbook_attestation.schema.json",
  "title": "Incident Response Runbook Attestation",
  "type": "object",
  "required": [
    "runbookApproved",
    "ownerRole",
    "reviewWindowDays"
  ],
  "properties": {
    "runbookApproved": {
      "type": "boolean"
    },
    "ownerRole": {
      "type": "string",
      "minLength": 1
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TLS Ingress Configuration Payload",
  "type": "object",
  "required": [
    "httpsOnly",
    "minTlsVersion",
    "managedCertificatesActive",
    "plaintextDisabled"
  ],
  "properties": {
    "httpsOnly": {
      "type": "boolean"
    },
    "minTlsVersion": {
      "type": "string",
      "enum": [
        "1.2",
        "1.3"
      ]
    },
    "managedCertificatesActive": {
      "type": "boolean"
    },
    "plaintextDisabled": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}

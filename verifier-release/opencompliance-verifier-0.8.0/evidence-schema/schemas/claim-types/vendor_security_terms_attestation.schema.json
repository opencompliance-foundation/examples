{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/vendor_security_terms_attestation.schema.json",
  "title": "Vendor Security Terms Attestation",
  "type": "object",
  "required": [
    "requiredSecurityTermsPresent",
    "privacyTermsPresent",
    "highRiskVendorsCovered",
    "reviewWindowDays"
  ],
  "properties": {
    "requiredSecurityTermsPresent": {
      "type": "boolean"
    },
    "privacyTermsPresent": {
      "type": "boolean"
    },
    "highRiskVendorsCovered": {
      "type": "integer",
      "minimum": 0
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

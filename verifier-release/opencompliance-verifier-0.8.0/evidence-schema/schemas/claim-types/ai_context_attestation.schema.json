{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/ai_context_attestation.schema.json",
  "title": "AI Context Attestation",
  "type": "object",
  "required": [
    "intendedUseDocumented",
    "deploymentContextDocumented",
    "ownerAssigned",
    "reviewWindowDays"
  ],
  "properties": {
    "intendedUseDocumented": {
      "type": "boolean"
    },
    "deploymentContextDocumented": {
      "type": "boolean"
    },
    "ownerAssigned": {
      "type": "boolean"
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/ai_evaluation_attestation.schema.json",
  "title": "AI Evaluation Attestation",
  "type": "object",
  "required": [
    "evaluationScopeDocumented",
    "testingLayersDocumented",
    "findingsCaptured",
    "reviewWindowDays"
  ],
  "properties": {
    "evaluationScopeDocumented": {
      "type": "boolean"
    },
    "testingLayersDocumented": {
      "type": "boolean"
    },
    "findingsCaptured": {
      "type": "boolean"
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

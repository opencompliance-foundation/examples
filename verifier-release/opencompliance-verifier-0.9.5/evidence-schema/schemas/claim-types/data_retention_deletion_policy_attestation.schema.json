{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/data_retention_deletion_policy_attestation.schema.json",
  "title": "Data Retention and Deletion Policy Attestation",
  "type": "object",
  "required": [
    "policyApproved",
    "reviewWindowDays",
    "dataClassesCovered"
  ],
  "properties": {
    "policyApproved": {
      "type": "boolean"
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    },
    "dataClassesCovered": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

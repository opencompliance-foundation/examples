{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/disciplinary_policy_attestation.schema.json",
  "title": "Disciplinary Policy Attestation",
  "type": "object",
  "required": [
    "policyCurrent",
    "populationsCovered",
    "reviewWindowDays"
  ],
  "properties": {
    "policyCurrent": {
      "type": "boolean"
    },
    "populationsCovered": {
      "type": "integer",
      "minimum": 1
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

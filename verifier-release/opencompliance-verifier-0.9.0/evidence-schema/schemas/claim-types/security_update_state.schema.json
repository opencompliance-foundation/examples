{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/security_update_state.schema.json",
  "title": "Security Update State",
  "type": "object",
  "required": [
    "supportedVersionsOnly",
    "criticalOverdueCount",
    "patchWindowDays"
  ],
  "properties": {
    "supportedVersionsOnly": {
      "type": "boolean"
    },
    "criticalOverdueCount": {
      "type": "integer",
      "minimum": 0
    },
    "patchWindowDays": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

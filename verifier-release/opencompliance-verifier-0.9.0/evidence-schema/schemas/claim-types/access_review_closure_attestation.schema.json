{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/access_review_closure_attestation.schema.json",
  "title": "Access Review Closure Attestation",
  "type": "object",
  "required": [
    "reviewCompleted",
    "reviewWindowDays",
    "reviewPopulation",
    "highRiskFindingsOpen"
  ],
  "properties": {
    "reviewCompleted": {
      "type": "boolean"
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    },
    "reviewPopulation": {
      "type": "string",
      "minLength": 1
    },
    "highRiskFindingsOpen": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}

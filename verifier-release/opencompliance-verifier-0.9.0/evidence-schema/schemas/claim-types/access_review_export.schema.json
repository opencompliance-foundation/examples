{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Access Review Export Payload",
  "type": "object",
  "required": [
    "reviewWindowDays",
    "reviewCompleted",
    "reviewPopulation"
  ],
  "properties": {
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    },
    "reviewCompleted": {
      "type": "boolean"
    },
    "reviewPopulation": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}

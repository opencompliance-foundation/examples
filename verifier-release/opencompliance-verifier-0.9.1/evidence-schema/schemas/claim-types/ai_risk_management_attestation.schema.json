{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/ai_risk_management_attestation.schema.json",
  "title": "AI Risk Management Attestation",
  "type": "object",
  "required": [
    "riskProcessDocumented",
    "riskTolerancesDeclared",
    "reviewWindowDays"
  ],
  "properties": {
    "riskProcessDocumented": {
      "type": "boolean"
    },
    "riskTolerancesDeclared": {
      "type": "boolean"
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/supporting_utility_protection_attestation.schema.json",
  "title": "Supporting Utility Protection Attestation",
  "type": "object",
  "required": [
    "protectionsCurrent",
    "reviewWindowDays",
    "contingencyCoverageDeclared"
  ],
  "properties": {
    "protectionsCurrent": {
      "type": "boolean"
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    },
    "contingencyCoverageDeclared": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/isms_context_review_attestation.schema.json",
  "title": "ISMS Context Review Attestation",
  "type": "object",
  "required": [
    "reviewPerformed",
    "scopeAdjustmentsTracked",
    "reviewWindowDays"
  ],
  "properties": {
    "reviewPerformed": {
      "type": "boolean"
    },
    "scopeAdjustmentsTracked": {
      "type": "boolean"
    },
    "reviewWindowDays": {
      "type": "integer",
      "minimum": 1
    }
  },
  "additionalProperties": false
}

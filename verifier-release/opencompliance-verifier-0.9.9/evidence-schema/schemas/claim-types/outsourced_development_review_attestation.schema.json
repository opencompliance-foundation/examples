{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/claim-types/outsourced_development_review_attestation.schema.json",
  "title": "Outsourced Development Review Attestation",
  "type": "object",

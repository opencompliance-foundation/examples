{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opencompliancefoundation.com/schemas/evidence-claim.schema.json",
  "title": "OpenCompliance Evidence Claim",
  "type": "object",
  "required": [
    "claimId",
    "claimType",
    "collectedAt",
    "sourceSystem",
    "actor",
    "trustPolicyRef",
    "controlMappings",
    "payload"
  ],
  "properties": {
    "claimId": {
      "type": "string",
      "minLength": 1
    },
    "claimType": {
      "type": "string",
      "minLength": 1
    },
    "collectedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceSystem": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "actorId",
        "actorType"
      ],
      "properties": {
        "actorId": {
          "type": "string",
          "minLength": 1
        },
        "actorType": {
          "type": "string",
          "enum": [
            "system",
            "human",
            "delegated_approver",
            "verifier_service",
            "independent_witness"
          ]
        },
        "actorRole": {
          "type": "string",
          "minLength": 1
        },
        "organizationScope": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "trustPolicyRef": {
      "type": "string",
      "minLength": 1
    },
    "controlMappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "framework",
          "family",
          "controlId"
        ],
        "properties": {
          "framework": {
            "type": "string",
            "minLength": 1
          },
          "family": {
            "type": "string",
            "minLength": 1
          },
          "controlId": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "scope": {
      "type": "object",
      "properties": {
        "environment": {
          "type": "string"
        },
        "assetGroup": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "payload": {
      "type": "object"
    },
    "freshness": {
      "type": "object",
      "properties": {
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "evaluatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    },
    "signer": {
      "type": "object",
      "required": [
        "signerId",
        "signerType",
        "signatureType",
        "signedAt",
        "signerRole",
        "trustPolicyId"
      ],
      "properties": {
        "signerId": {
          "type": "string",
          "minLength": 1
        },
        "signerType": {
          "type": "string",
          "enum": [
            "human",
            "delegated_approver",
            "verifier_service",
            "independent_witness"
          ]
        },
        "signatureType": {
          "type": "string",
          "minLength": 1
        },
        "signedAt": {
          "type": "string",
          "format": "date-time"
        },
        "signerRole": {
          "type": "string",
          "minLength": 1
        },
        "trustPolicyId": {
          "type": "string",
          "minLength": 1
        },
        "delegatedBy": {
          "type": "string",
          "minLength": 1
        },
        "delegationScope": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "properties": {
        "exportId": {
          "type": "string",
          "minLength": 1
        },
        "collectionMethod": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "type": "string",
          "minLength": 1
        },
        "digestAlgorithm": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
